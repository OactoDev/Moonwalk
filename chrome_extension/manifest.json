{
  "manifest_version": 3,
  "name": "Moonwalk Browser Bridge",
  "version": "0.1.0",
  "description": "Stable DOM bridge for Moonwalk browser automation.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://127.0.0.1:8765 http://127.0.0.1:8765;"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["Readability.js", "content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Moonwalk Browser Bridge",
    "default_popup": "popup.html"
  }
}
